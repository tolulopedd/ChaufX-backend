{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@driveme/config": [
        "packages/config/src"
      ],
      "@driveme/types": [
        "packages/types/src"
      ],
      "@driveme/ui": [
        "packages/ui/src"
      ],
      "@driveme/design-tokens": [
        "packages/design-tokens/src"
      ]
    }
  }
}
